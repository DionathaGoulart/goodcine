# =============================================================================
# CineSync Web — Variáveis de Ambiente
# Copie este arquivo para .env e preencha com seus valores reais.
# NUNCA commite o .env com valores reais no git.
# =============================================================================

# --- Supabase (obrigatório) ---
# Configurações > API no painel do Supabase
NEXT_PUBLIC_SUPABASE_URL=https://SEU_PROJETO.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=sua_anon_key_aqui

# --- TMDB (obrigatório) ---
# themoviedb.org > Configurações > API > "API Read Access Token (v4 auth)"
TMDB_BEARER_TOKEN=seu_bearer_token_aqui
